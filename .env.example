# Discord bot token
DISCORD_TOKEN=your_bot_token_here

# Discord OAuth configuration
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Application URLs
PUBLIC_BASE_URL=http://localhost:8080
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# Session and security
SESSION_SECRET=your_secure_random_string_here

# Admin user IDs (comma-separated Discord user IDs)
ADMIN_USER_IDS=123456789,987654321

# Server configuration
PORT=8080
HOST=0.0.0.0
TRUST_PROXY=true

# Logging
LOG_LEVEL=info

# Environment
NODE_ENV=production

# Cache configuration
CACHE_DIR=/data/cache
CACHE_MAX_MB=5000

# Music player timeouts
IDLE_TIMEOUT_SEC=300

# History and search limits
HISTORY_MAX_ITEMS=100
SEARCH_RESULT_COUNT=10

# Download configuration
PREFETCH_DEPTH=3
MAX_TRANSCODE_JOBS=4
MAX_TRACK_DURATION_SEC=3600

# Audio processing
SPONSORBLOCK_REMOVE=sponsor,intro,outro,selfpromo
NORMALIZE_LOUDNESS=false

# YouTube configuration
YT_PROXY=
YT_COOKIES=
PO_TOKEN_PROVIDER_URL=
YT_PLAYER_CLIENTS=web,mweb
ALLOWED_WS_ORIGINS=http://localhost:3000
